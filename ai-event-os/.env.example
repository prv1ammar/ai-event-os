# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aievent:aievent_pass@localhost:5432/aievent_db

# ── Cache / Queue ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Auth ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-very-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── External APIs ──────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=AI EVENT OS
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── pgAdmin ────────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@aievents.ma
PGADMIN_PASSWORD=pgadmin_secret
